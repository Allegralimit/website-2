---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About — ${SITE_TITLE}`} description="Learn about Das Law — our mission, values, and the attorneys dedicated to serving you." />
	</head>
	<body>
		<Header />
		<main>
			<section class="page-header">
				<h1>About Das Law</h1>
				<p>Dedicated legal professionals committed to justice, integrity, and your success.</p>
			</section>

			<!-- Firm Overview -->
			<section class="section">
				<h2>Our Firm</h2>
				<p>Das Law was founded on the principle that everyone deserves access to exceptional legal representation. We combine deep legal knowledge with a genuine commitment to our clients' well-being, providing personalized counsel across a wide range of practice areas.</p>
				<p>Our attorneys take the time to understand each client's unique situation, crafting legal strategies tailored to achieve the best possible outcomes. Whether you're navigating a family dispute, planning your estate, growing your business, or defending your rights, Das Law is here to guide you every step of the way.</p>
			</section>

			<!-- Mission -->
			<section class="section mission-section">
				<h2>Our Mission</h2>
				<p class="mission-text">To provide compassionate, results-driven legal services that empower individuals and families to protect what matters most — their rights, their livelihoods, and their futures.</p>
			</section>

			<!-- Attorney Bios -->
			<section class="section">
				<h2>Our Team</h2>
				<p class="team-intro">Our attorneys bring diverse experience and a shared commitment to excellence.</p>
				<div class="team-list">
					<div class="attorney-item">
						<h3>Attorney Name</h3>
						<p class="attorney-role">Founding Partner</p>
						<p>Bio coming soon.</p>
					</div>
					<div class="attorney-item">
						<h3>Attorney Name</h3>
						<p class="attorney-role">Associate Attorney</p>
						<p>Bio coming soon.</p>
					</div>
					<div class="attorney-item">
						<h3>Attorney Name</h3>
						<p class="attorney-role">Associate Attorney</p>
						<p>Bio coming soon.</p>
					</div>
				</div>
			</section>

			<!-- Values -->
			<section class="section">
				<h2>Our Values</h2>
				<div class="values-list">
					<div class="value-item">
						<h3>Integrity</h3>
						<p>We uphold the highest ethical standards in every case and every interaction.</p>
					</div>
					<div class="value-item">
						<h3>Advocacy</h3>
						<p>We fight tenaciously for our clients' rights and interests.</p>
					</div>
					<div class="value-item">
						<h3>Compassion</h3>
						<p>We treat every client with empathy, respect, and understanding.</p>
					</div>
					<div class="value-item">
						<h3>Excellence</h3>
						<p>We pursue the highest quality of legal work in everything we do.</p>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header {
		padding: 2rem 0 1.5rem;
		border-bottom: 2px solid var(--accent);
		margin-bottom: 2rem;
	}
	.page-header h1 {
		font-size: 2rem;
		color: var(--text-dark);
	}
	.page-header p {
		color: var(--text-muted);
		margin-top: 0.5rem;
		font-size: 1.05rem;
	}

	.section {
		margin-bottom: 2.5rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--border-light);
	}
	.section:last-child {
		border-bottom: none;
	}
	.section h2 {
		font-size: 1.6rem;
		color: var(--text-dark);
		margin-bottom: 1rem;
	}
	.section p {
		color: var(--text-dark);
		line-height: 1.7;
	}

	/* Mission */
	.mission-section {
		background: #ffffff;
		padding: 2rem;
		text-align: center;
		box-shadow: var(--panel-shadow);
	}
	.mission-text {
		font-size: 1.1rem;
		font-style: italic;
		color: var(--accent-dark);
		max-width: 640px;
		margin: 0 auto;
		line-height: 1.6;
	}

	/* Team */
	.team-intro {
		color: var(--text-muted);
		margin-bottom: 1.5rem;
	}
	.team-list {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}
	.attorney-item {
		background: #ffffff;
		padding: 1.5rem;
		box-shadow: var(--panel-shadow);
	}
	.attorney-item h3 {
		font-size: 1.1rem;
		color: var(--text-dark);
		margin-bottom: 0.2rem;
	}
	.attorney-role {
		color: var(--accent);
		font-weight: 700;
		font-size: 0.85rem;
		margin-bottom: 0.5rem;
	}
	.attorney-item p:last-child {
		color: var(--text-muted);
		font-size: 0.9rem;
		margin: 0;
	}

	/* Values */
	.values-list {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.25rem;
	}
	.value-item {
		padding: 1.25rem;
		background: #ffffff;
		border-left: 3px solid var(--accent);
		box-shadow: var(--panel-shadow);
	}
	.value-item h3 {
		font-size: 1.05rem;
		color: var(--text-dark);
		margin-bottom: 0.4rem;
	}
	.value-item p {
		color: var(--text-muted);
		font-size: 0.92rem;
		margin: 0;
		line-height: 1.5;
	}

	@media (max-width: 720px) {
		.team-list {
			grid-template-columns: 1fr;
		}
		.values-list {
			grid-template-columns: 1fr;
		}
	}
</style>
