---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description="Legal insights and updates from Das Law." />
	</head>
	<body>
		<Header />
		<main>
			<section class="page-header">
				<h1>Blog</h1>
				<p>Legal insights, news, and updates from Das Law.</p>
			</section>

			<div class="empty-state">
				<p>📝 Blog posts coming soon.</p>
				<p>Check back for articles on legal topics, firm news, and helpful resources.</p>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header {
		padding: 3rem 0 2rem;
		border-bottom: 1px solid rgb(var(--gray-light));
		margin-bottom: 2.5rem;
		text-align: center;
	}
	.page-header h1 {
		font-size: 2.4rem;
		color: #1a2744;
	}
	.page-header p {
		color: rgb(var(--gray));
		margin-top: 0.5rem;
	}
	.empty-state {
		text-align: center;
		padding: 4rem 1rem;
		color: rgb(var(--gray));
	}
	.empty-state p:first-child {
		font-size: 1.3rem;
		margin-bottom: 0.5rem;
	}
</style>
