---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description="Legal insights and updates from Das Law." />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-panel">
				<h1>Blog</h1>
				<p class="subtitle">Legal insights, news, and updates from Das Law.</p>
			</div>

			<div class="content-panel">
				<div class="empty-state">
					<p class="empty-icon">📝</p>
					<p class="empty-title">Blog posts coming soon.</p>
					<p>Check back for articles on legal topics, firm news, and helpful resources.</p>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-panel {
		background: #ffffff;
		padding: 2rem 2.5rem;
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
		margin-bottom: 1.5rem;
	}
	.page-panel h1 {
		font-size: 2rem;
		color: #2d2d2d;
		margin-bottom: 0.25rem;
	}
	.subtitle {
		color: #666666;
		margin: 0;
	}
	.content-panel {
		background: #ffffff;
		padding: 2rem 2.5rem;
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
	}
	.empty-state {
		text-align: center;
		padding: 3rem 1rem;
		color: #666666;
	}
	.empty-icon {
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
	}
	.empty-title {
		font-size: 1.2rem;
		font-weight: 700;
		color: #333333;
		margin-bottom: 0.5rem;
	}
	.empty-state p:last-child {
		font-size: 0.95rem;
		margin: 0;
	}
</style>
