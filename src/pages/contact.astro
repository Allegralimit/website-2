---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Contact Us — ${SITE_TITLE}`} description="Schedule a consultation with Das Law. We're here to help with your legal needs." />
	</head>
	<body>
		<Header />
		<main>
			<section class="page-header">
				<h1>Contact Us</h1>
				<p>Schedule a consultation or ask us a question. We're here to help.</p>
			</section>

			<div class="contact-layout">
				<form class="contact-form" action="#" method="POST">
					<h2>Schedule a Consultation</h2>
					<div class="form-group">
						<label for="name">Full Name</label>
						<input type="text" id="name" name="name" required />
					</div>
					<div class="form-group">
						<label for="email">Email</label>
						<input type="email" id="email" name="email" required />
					</div>
					<div class="form-group">
						<label for="phone">Phone Number</label>
						<input type="tel" id="phone" name="phone" placeholder="(555) 123-4567" />
					</div>
					<div class="form-group">
						<label for="subject">How Can We Help?</label>
						<select id="subject" name="subject" required>
							<option value="" disabled selected>Select a practice area...</option>
							<option value="family-law">Family Law</option>
							<option value="estate-planning">Estate Planning</option>
							<option value="business-law">Business Law</option>
							<option value="criminal-defense">Criminal Defense</option>
							<option value="immigration">Immigration</option>
							<option value="personal-injury">Personal Injury</option>
							<option value="other">Other / Not Sure</option>
						</select>
					</div>
					<div class="form-group">
						<label for="message">Tell Us About Your Situation</label>
						<textarea id="message" name="message" required></textarea>
					</div>
					<button type="submit">Send Message</button>
				</form>

				<aside class="contact-info">
					<h2>Get in Touch</h2>
					<div class="info-block">
						<h3>📍 Office</h3>
						<p>123 Main Street, Suite 400<br />City, State 12345</p>
					</div>
					<div class="info-block">
						<h3>📞 Phone</h3>
						<p><a href="tel:+15551234567">(555) 123-4567</a></p>
					</div>
					<div class="info-block">
						<h3>✉️ Email</h3>
						<p><a href="mailto:contact@thedaslaw.com">contact@thedaslaw.com</a></p>
					</div>
					<div class="info-block">
						<h3>🕐 Office Hours</h3>
						<p>Monday – Friday: 9:00 AM – 5:00 PM<br />Weekends: By appointment only</p>
					</div>
				</aside>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header {
		padding: 3rem 0 2rem;
		border-bottom: 1px solid rgb(var(--gray-light));
		margin-bottom: 2.5rem;
		text-align: center;
	}
	.page-header h1 {
		font-size: 2.4rem;
		color: #1a2744;
	}
	.page-header p {
		color: rgb(var(--gray));
		margin-top: 0.5rem;
	}
	.contact-layout {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		gap: 3rem;
		align-items: start;
	}
	.contact-form h2,
	.contact-info h2 {
		font-size: 1.4rem;
		color: #1a2744;
		margin-bottom: 1.5rem;
	}
	.form-group {
		margin-bottom: 1.5rem;
	}
	.form-group label {
		display: block;
		font-size: 0.9rem;
		font-weight: 700;
		margin-bottom: 0.4rem;
		color: rgb(var(--gray-dark));
	}
	.form-group input,
	.form-group textarea,
	.form-group select {
		width: 100%;
		padding: 0.7rem;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 4px;
		font-family: inherit;
		font-size: 1rem;
		background: #fff;
		color: rgb(var(--gray-dark));
	}
	.form-group textarea {
		min-height: 150px;
		resize: vertical;
	}
	.form-group input:focus,
	.form-group textarea:focus,
	.form-group select:focus {
		outline: none;
		border-color: #c9a84c;
		box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.15);
	}
	button[type="submit"] {
		padding: 0.8rem 2.5rem;
		background: #c9a84c;
		color: #1a2744;
		border: none;
		border-radius: 4px;
		font-size: 1rem;
		font-weight: 700;
		cursor: pointer;
		transition: background 0.2s;
	}
	button[type="submit"]:hover {
		background: #a07d2e;
		color: #ffffff;
	}
	.contact-info {
		background: #f8f9fa;
		padding: 2rem;
		border-radius: 8px;
	}
	.info-block {
		margin-bottom: 1.5rem;
	}
	.info-block:last-child {
		margin-bottom: 0;
	}
	.info-block h3 {
		font-size: 1rem;
		color: #1a2744;
		margin-bottom: 0.3rem;
	}
	.info-block p {
		color: rgb(var(--gray));
		font-size: 0.95rem;
		margin: 0;
		line-height: 1.6;
	}
	.info-block a {
		color: var(--accent-dark);
		text-decoration: none;
	}
	.info-block a:hover {
		color: var(--accent);
	}
	@media (max-width: 720px) {
		.contact-layout {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 480px) {
		.page-header h1 {
			font-size: 1.8rem;
		}
	}
</style>
