---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main>
			<div class="two-col">
				<!-- Left Column: Services -->
				<div class="services-col">
					<h1>Services We Offer</h1>

					<div class="service-group">
						<h2>Family Law</h2>
						<ul>
							<li>Divorce &amp; Legal Separation</li>
							<li>Child Custody &amp; Visitation</li>
							<li>Child Support</li>
							<li>Spousal Support / Alimony</li>
							<li>Adoption</li>
							<li>Prenuptial &amp; Postnuptial Agreements</li>
							<li>Domestic Violence Protective Orders</li>
						</ul>
					</div>

					<div class="service-group">
						<h2>Estate Planning</h2>
						<ul>
							<li>Wills &amp; Living Wills</li>
							<li>Revocable &amp; Irrevocable Trusts</li>
							<li>Powers of Attorney</li>
							<li>Probate &amp; Estate Administration</li>
							<li>Guardianship &amp; Conservatorship</li>
							<li>Asset Protection</li>
						</ul>
					</div>

					<div class="service-group">
						<h2>Business Law</h2>
						<ul>
							<li>Entity Formation &amp; Structuring</li>
							<li>Contract Drafting &amp; Negotiation</li>
							<li>Business Disputes &amp; Litigation</li>
							<li>Mergers &amp; Acquisitions</li>
							<li>Employment Law Compliance</li>
						</ul>
					</div>

					<div class="service-group">
						<h2>Criminal Defense</h2>
						<ul>
							<li>Felony &amp; Misdemeanor Charges</li>
							<li>DUI / DWI Defense</li>
							<li>Drug Offenses</li>
							<li>White-Collar Crimes</li>
							<li>Federal Charges</li>
						</ul>
					</div>

					<div class="service-group">
						<h2>Immigration</h2>
						<ul>
							<li>Family &amp; Employment-Based Visas</li>
							<li>Green Card Applications</li>
							<li>Naturalization &amp; Citizenship</li>
							<li>Deportation Defense</li>
							<li>Asylum &amp; Refugee Cases</li>
						</ul>
					</div>

					<div class="service-group">
						<h2>Personal Injury</h2>
						<ul>
							<li>Auto Accidents</li>
							<li>Slip &amp; Fall Injuries</li>
							<li>Medical Malpractice</li>
							<li>Workplace Injuries</li>
							<li>Wrongful Death Claims</li>
						</ul>
					</div>
				</div>

				<!-- Right Column: Contact Card -->
				<div class="contact-col">
					<div class="contact-card">
						<h2>Contact Us</h2>
						<p class="appt-note">Consultations by Appointment Only</p>
						<div class="contact-details">
							<p><strong>Das Law</strong></p>
							<p>123 Main Street, Suite 400<br />City, State 12345</p>
							<p><a href="mailto:contact@thedaslaw.com">contact@thedaslaw.com</a></p>
							<p><a href="tel:+15555555555">(555) 555-5555</a></p>
						</div>
						<form class="contact-form" action="#" method="POST">
							<input type="text" name="name" placeholder="Name" required />
							<input type="email" name="email" placeholder="Email" required />
							<input type="text" name="subject" placeholder="Subject" />
							<input type="tel" name="phone" placeholder="Phone" />
							<textarea name="message" placeholder="Message" rows="5" required></textarea>
							<button type="submit">Send</button>
						</form>
					</div>
				</div>
			</div>

			<!-- Schedule CTA -->
			<section class="cta-section">
				<h2>Schedule a Consultation</h2>
				<p>Whether you need help with a family matter, estate planning, business issue, or any other legal concern, our experienced attorneys are ready to assist you.</p>
				<a href="/contact" class="cta-link">Contact Us Today &rarr;</a>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	/* Two-column layout */
	.two-col {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 2.5rem;
		align-items: start;
	}

	/* Services column */
	.services-col h1 {
		font-size: 1.8rem;
		color: var(--text-dark);
		margin-bottom: 1.5rem;
		border-bottom: 2px solid var(--accent);
		padding-bottom: 0.5rem;
	}
	.service-group {
		margin-bottom: 1.5rem;
	}
	.service-group h2 {
		font-size: 1.2rem;
		color: var(--accent);
		margin-bottom: 0.4rem;
	}
	.service-group ul {
		margin: 0 0 0.5rem 0;
		padding-left: 1.25rem;
		list-style: disc;
	}
	.service-group li {
		font-size: 0.92rem;
		line-height: 1.7;
		color: var(--text-dark);
	}

	/* Contact card */
	.contact-card {
		background: #3d3d3d;
		color: #ffffff;
		padding: 1.75rem;
	}
	.contact-card h2 {
		color: #ffffff;
		font-size: 1.4rem;
		margin-bottom: 0.5rem;
	}
	.appt-note {
		font-style: italic;
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.7);
		margin-bottom: 1rem;
	}
	.contact-details {
		margin-bottom: 1.25rem;
		font-size: 0.9rem;
		line-height: 1.6;
	}
	.contact-details p {
		margin-bottom: 0.3rem;
	}
	.contact-details a {
		color: #a8c4d0;
		text-decoration: none;
	}
	.contact-details a:hover {
		color: #ffffff;
	}
	.contact-form input,
	.contact-form textarea {
		display: block;
		width: 100%;
		padding: 0.55rem 0.7rem;
		margin-bottom: 0.6rem;
		border: 1px solid #555;
		background: #4a4a4a;
		color: #ffffff;
		font-family: inherit;
		font-size: 0.9rem;
	}
	.contact-form input::placeholder,
	.contact-form textarea::placeholder {
		color: rgba(255, 255, 255, 0.5);
	}
	.contact-form textarea {
		resize: vertical;
	}
	.contact-form button {
		display: block;
		width: 100%;
		padding: 0.6rem;
		background: var(--accent);
		color: #ffffff;
		border: none;
		font-size: 0.95rem;
		font-weight: 700;
		cursor: pointer;
		transition: background 0.2s;
	}
	.contact-form button:hover {
		background: var(--accent-dark);
	}

	/* CTA section */
	.cta-section {
		text-align: center;
		padding: 2.5rem 1rem;
		margin-top: 2rem;
		border-top: 1px solid var(--border-light);
	}
	.cta-section h2 {
		font-size: 1.6rem;
		color: var(--text-dark);
		margin-bottom: 0.75rem;
	}
	.cta-section p {
		max-width: 600px;
		margin: 0 auto 1.25rem;
		color: var(--text-muted);
		line-height: 1.6;
	}
	.cta-link {
		display: inline-block;
		padding: 0.7rem 2rem;
		background: var(--accent);
		color: #ffffff;
		text-decoration: none;
		font-weight: 700;
		transition: background 0.2s;
	}
	.cta-link:hover {
		background: var(--accent-dark);
		color: #ffffff;
	}

	/* Responsive */
	@media (max-width: 720px) {
		.two-col {
			grid-template-columns: 1fr;
		}
	}
</style>
