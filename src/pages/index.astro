---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="hero">
			<div class="hero-mesh"></div>
			<div class="hero-content">
				<h1>Protecting What Matters Most</h1>
				<p class="hero-tagline">Experienced attorneys committed to defending your rights, safeguarding your family, and securing your future.</p>
				<a href="/contact" class="cta-button">Schedule a Consultation</a>
			</div>
		</section>

		<main>
			<!-- Practice Areas -->
			<section class="section">
				<h2 class="section-title">Our Practice Areas</h2>
				<p class="section-subtitle">Comprehensive legal services tailored to your needs</p>
				<div class="practice-grid">
					<div class="practice-card">
						<div class="card-icon">⚖️</div>
						<h3>Family Law</h3>
						<p>Divorce, custody, adoption, and support matters handled with compassion and expertise.</p>
					</div>
					<div class="practice-card">
						<div class="card-icon">📜</div>
						<h3>Estate Planning</h3>
						<p>Wills, trusts, and probate to protect your legacy and provide for your loved ones.</p>
					</div>
					<div class="practice-card">
						<div class="card-icon">🏢</div>
						<h3>Business Law</h3>
						<p>Entity formation, contracts, and compliance to help your business thrive.</p>
					</div>
					<div class="practice-card">
						<div class="card-icon">🛡️</div>
						<h3>Criminal Defense</h3>
						<p>Aggressive defense of your rights from investigation through trial and appeal.</p>
					</div>
					<div class="practice-card">
						<div class="card-icon">🌐</div>
						<h3>Immigration</h3>
						<p>Visas, green cards, citizenship, and deportation defense for individuals and families.</p>
					</div>
					<div class="practice-card">
						<div class="card-icon">🩹</div>
						<h3>Personal Injury</h3>
						<p>Fighting for the compensation you deserve after accidents and injuries.</p>
					</div>
				</div>
			</section>

			<!-- Why Choose Das Law -->
			<section class="section why-section">
				<h2 class="section-title">Why Choose Das Law</h2>
				<div class="values-grid">
					<div class="value-card">
						<h3>Decades of Experience</h3>
						<p>Our attorneys bring extensive courtroom and negotiation experience across a wide range of legal matters.</p>
					</div>
					<div class="value-card">
						<h3>Personal Attention</h3>
						<p>Every client receives individualized counsel. You'll always know your attorney and have direct access to your legal team.</p>
					</div>
					<div class="value-card">
						<h3>Results-Driven</h3>
						<p>We focus on achieving the best possible outcomes — whether through skilled negotiation or tenacious litigation.</p>
					</div>
					<div class="value-card">
						<h3>Community Commitment</h3>
						<p>Rooted in the community we serve, we're dedicated to making quality legal representation accessible to all.</p>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* ── Hero ── */
	.hero {
		position: relative;
		background: linear-gradient(135deg, #0f1724 0%, #1a2744 50%, #243b6e 100%);
		padding: 6rem 1.5rem 5rem;
		text-align: center;
		overflow: hidden;
	}
	.hero-mesh {
		position: absolute;
		inset: 0;
		opacity: 0.05;
		background-image:
			linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px);
		background-size: 60px 60px;
	}
	.hero-content {
		position: relative;
		z-index: 1;
		max-width: 720px;
		margin: 0 auto;
	}
	.hero h1 {
		font-size: 3rem;
		color: #ffffff;
		margin-bottom: 1rem;
	}
	.hero-tagline {
		color: rgba(255, 255, 255, 0.8);
		font-size: 1.2rem;
		margin-bottom: 2rem;
		line-height: 1.6;
	}
	.cta-button {
		display: inline-block;
		padding: 0.9rem 2.5rem;
		background: #c9a84c;
		color: #1a2744;
		text-decoration: none;
		font-weight: 700;
		font-size: 1.1rem;
		border-radius: 4px;
		transition: background 0.2s, transform 0.2s;
	}
	.cta-button:hover {
		background: #a07d2e;
		color: #ffffff;
		transform: translateY(-2px);
	}
	.hero::after {
		content: '';
		position: absolute;
		bottom: -1px;
		left: 0;
		right: 0;
		height: 60px;
		background: white;
		border-radius: 50% 50% 0 0 / 100% 100% 0 0;
	}

	/* ── Sections ── */
	.section {
		margin-bottom: 4rem;
	}
	.section-title {
		font-size: 2rem;
		color: #1a2744;
		text-align: center;
		margin-bottom: 0.5rem;
	}
	.section-subtitle {
		text-align: center;
		color: rgb(var(--gray));
		margin-bottom: 2.5rem;
		font-size: 1.1rem;
	}

	/* ── Practice Area Cards ── */
	.practice-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}
	.practice-card {
		background: #ffffff;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		padding: 2rem 1.5rem;
		text-align: center;
		transition: box-shadow 0.2s, transform 0.2s;
	}
	.practice-card:hover {
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
		transform: translateY(-4px);
	}
	.card-icon {
		font-size: 2.5rem;
		margin-bottom: 1rem;
	}
	.practice-card h3 {
		font-size: 1.3rem;
		color: #1a2744;
		margin-bottom: 0.5rem;
	}
	.practice-card p {
		color: rgb(var(--gray));
		font-size: 0.95rem;
		line-height: 1.5;
		margin: 0;
	}

	/* ── Why Choose ── */
	.why-section {
		background: #f8f9fa;
		margin-left: -1em;
		margin-right: -1em;
		padding: 3rem 1em;
		border-radius: 8px;
	}
	.values-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
	}
	.value-card {
		padding: 1.5rem;
	}
	.value-card h3 {
		font-size: 1.2rem;
		color: #1a2744;
		margin-bottom: 0.5rem;
	}
	.value-card h3::before {
		content: '✓ ';
		color: #c9a84c;
		font-weight: 700;
	}
	.value-card p {
		color: rgb(var(--gray));
		font-size: 0.95rem;
		margin: 0;
		line-height: 1.6;
	}

	/* ── Responsive ── */
	@media (max-width: 720px) {
		.hero {
			padding: 4rem 1rem 3rem;
		}
		.hero h1 {
			font-size: 2.2rem;
		}
		.practice-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.values-grid {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 480px) {
		.hero h1 {
			font-size: 1.8rem;
		}
		.hero-tagline {
			font-size: 1rem;
		}
		.practice-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
