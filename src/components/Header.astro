---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<div class="top-bar">
		<div class="top-bar-inner">
			<div class="firm-name"><a href="/">{SITE_TITLE}</a></div>
			<div class="phone"><a href="tel:+15555555555">(555) 555-5555</a></div>
		</div>
	</div>
	<nav>
		<div class="nav-inner">
			<button class="menu-toggle" aria-label="Toggle navigation" aria-expanded="false">
				☰ Menu
			</button>
			<div class="nav-links">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
				<HeaderLink href="/practice-areas">Practice Areas</HeaderLink>
				<HeaderLink href="/contact">Contact</HeaderLink>
			</div>
		</div>
	</nav>
</header>

<script>
	const toggle = document.querySelector('.menu-toggle');
	const links = document.querySelector('.nav-links');
	if (toggle && links) {
		toggle.addEventListener('click', () => {
			const expanded = toggle.getAttribute('aria-expanded') === 'true';
			toggle.setAttribute('aria-expanded', String(!expanded));
			links.classList.toggle('open');
		});
	}
</script>

<style>
	header {
		margin: 0;
		position: sticky;
		top: 0;
		z-index: 100;
	}

	/* Top bar - dark charcoal with firm name and phone */
	.top-bar {
		background: #333333;
		padding: 0.75em 1em;
	}
	.top-bar-inner {
		max-width: 960px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.firm-name {
		font-family: Georgia, "Times New Roman", Times, serif;
		font-size: 1.6em;
		font-weight: 700;
		letter-spacing: 0.02em;
	}
	.firm-name a {
		color: #ffffff;
		text-decoration: none;
	}
	.firm-name a:hover {
		color: #cccccc;
	}
	.phone a {
		color: #ffffff;
		text-decoration: none;
		font-size: 1.1em;
		font-weight: 700;
	}
	.phone a:hover {
		color: #cccccc;
	}

	/* Nav bar - slate blue / steel blue */
	nav {
		background: #4a6a7a;
	}
	.nav-inner {
		max-width: 960px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		padding: 0 1em;
	}
	.nav-links {
		display: flex;
		align-items: center;
	}
	nav a {
		display: inline-block;
		padding: 0.7em 1.25em;
		color: #ffffff;
		text-decoration: none;
		font-size: 0.95em;
		transition: background 0.2s;
	}
	nav a:hover {
		background: rgba(255, 255, 255, 0.15);
		color: #ffffff;
	}
	nav a.active {
		background: rgba(255, 255, 255, 0.2);
		color: #ffffff;
		font-weight: 700;
	}
	.menu-toggle {
		display: none;
		background: none;
		border: none;
		color: #ffffff;
		font-size: 1em;
		cursor: pointer;
		padding: 0.75em 0;
	}

	@media (max-width: 600px) {
		.menu-toggle {
			display: block;
		}
		.nav-links {
			display: none;
			width: 100%;
			flex-direction: column;
			text-align: left;
			padding-bottom: 0.5em;
		}
		.nav-links.open {
			display: flex;
		}
		.nav-inner {
			flex-wrap: wrap;
		}
		.nav-links a {
			padding: 0.6em 1em;
			width: 100%;
		}
		.firm-name {
			font-size: 1.2em;
		}
		.phone a {
			font-size: 0.95em;
		}
	}
</style>
